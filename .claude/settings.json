{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/lint-hook.js || true",
            "statusMessage": "Auto-fixing lint..."
          },
          {
            "type": "command",
            "command": "node scripts/typecheck-hook.js || true",
            "statusMessage": "Type-checking..."
          }
        ]
      }
    ]
  }
}
