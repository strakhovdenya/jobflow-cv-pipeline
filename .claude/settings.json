{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint 2>/dev/null; npm run lint 2>/dev/null; npm run lint 2>/dev/null || true",
            "statusMessage": "Auto-fixing lint..."
          }
        ]
      }
    ]
  }
}
