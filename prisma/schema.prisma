generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceStatus {
  source_saved
  analysis_running
  analysis_ready
  paused_after_analysis
  skipped
  cv_generation_running
  cv_draft_ready
  paused_after_cv_draft
  pre_pdf_check_ready
  paused_before_export
  export_running
  cv_pdf_generated
  final_check_ready
  ready_to_apply
  cover_letter_generated
  applied
  rejected
  archived
  failed
}

enum VacancyDecision {
  apply
  maybe
  skip
  manual_override_apply
  manual_override_maybe
  manual_override_skip
}

enum UserReviewState {
  pending_review
  approved
  edited
  rejected
  overridden
}

model Company {
  id             String                 @id @default(cuid())
  nameOriginal   String
  companySlug    String
  normalizedName String?
  sourceType     String?
  notes          String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  workspaces     ApplicationWorkspace[]
  vacancies      JobVacancy[]
}

model JobVacancy {
  id                       String                @id @default(cuid())
  companyId                String
  roleTitleOriginal        String
  roleSlug                 String
  sourceUrl                String?
  languageDetected         String?
  locationText             String?
  remoteType               String?
  employmentType           String?
  seniority                String?
  vacancyTextPath          String
  vacancyTextHash          String
  vacancyTextSizeBytes     Int?
  sourceFormat             String?
  originalImportedFileName String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  company                  Company               @relation(fields: [companyId], references: [id])
  workspace                ApplicationWorkspace?
}

model ApplicationWorkspace {
  id                    String              @id @default(cuid())
  companyId             String
  jobVacancyId          String              @unique
  workspaceSlug         String              @unique
  storageRoot           String
  workspacePath         String
  status                WorkspaceStatus     @default(source_saved)
  currentDecision       VacancyDecision?
  reviewState           UserReviewState?
  score                 Int?
  skipReasonSummary     String?
  nextRecommendedAction String?
  isSkipped             Boolean             @default(false)
  isArchived            Boolean             @default(false)
  createdFrom           String
  sourceImportedPath    String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  lastActivityAt        DateTime?

  company               Company             @relation(fields: [companyId], references: [id])
  jobVacancy            JobVacancy          @relation(fields: [jobVacancyId], references: [id])
  artifacts             GeneratedArtifact[]
  promptRuns            PromptRun[]
  decisionOverrides     DecisionOverride[]
}

enum PromptRunStatus {
  pending
  running
  completed
  failed
}

model PromptTemplate {
  id          String   @id @default(cuid())
  promptKey   String
  step        String
  version     Int
  content     String
  isActive    Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  promptRuns  PromptRun[]
}

model AiRun {
  id                   String    @id @default(cuid())
  provider             String
  model                String
  status               String
  requestHash          String?
  responseHash         String?
  inputTokens          Int?
  outputTokens         Int?
  totalTokens          Int?
  cachedInputTokens    Int?
  reasoningTokens      Int?
  usageRawJson         String?
  costEstimate         Float?
  costCurrency         String?
  pricingConfigVersion String?
  errorMessage         String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  promptRun            PromptRun?
}

model PromptRun {
  id               String          @id @default(cuid())
  workspaceId      String
  promptStep       String
  templateId       String
  templateVersion  Int
  status           PromptRunStatus @default(pending)
  inputHash        String?
  sourceSnapshot   String?
  aiRunId          String?         @unique
  outputArtifactIds String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  workspace        ApplicationWorkspace @relation(fields: [workspaceId], references: [id])
  template         PromptTemplate       @relation(fields: [templateId], references: [id])
  aiRun            AiRun?               @relation(fields: [aiRunId], references: [id])
}

model KnowledgeSource {
  id           String   @id @default(cuid())
  filePath     String
  sourceType   String
  isActive     Boolean  @default(true)
  contentHash  String
  versionLabel String?
  importedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EvidenceItem {
  id          String   @id @default(cuid())
  claimArea   String
  category    String
  description String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DecisionOverride {
  id           String               @id @default(cuid())
  workspaceId  String
  fromDecision VacancyDecision
  toDecision   VacancyDecision
  reviewState  UserReviewState
  reasonNote   String?
  createdAt    DateTime             @default(now())

  workspace    ApplicationWorkspace @relation(fields: [workspaceId], references: [id])
}

model GeneratedArtifact {
  id                String               @id @default(cuid())
  workspaceId       String
  promptRunId       String?
  artifactType      String
  canonicalFileName String
  filePath          String
  storageRoot       String
  contentHash       String
  isLatest          Boolean              @default(true)
  version           Int                  @default(1)
  origin            String
  status            String               @default("ready")
  mimeType          String?
  fileSizeBytes     Int?
  downloadFileName  String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  workspace         ApplicationWorkspace @relation(fields: [workspaceId], references: [id])
}
