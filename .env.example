# --- PostgreSQL (Docker) ---
POSTGRES_USER=jobflow
POSTGRES_PASSWORD=jobflow_secret
POSTGRES_DB=jobflow_cv
POSTGRES_PORT=5432

# --- NestJS App ---
# Required: full PostgreSQL connection string
DATABASE_URL=postgresql://jobflow:jobflow_secret@localhost:5432/jobflow_cv

# Required: absolute path to artifact storage root
STORAGE_ROOT=/path/to/storage/applications

# Optional: root path for knowledge source content files (default: ./knowledge-sources)
KNOWLEDGE_SOURCES_ROOT=./knowledge-sources

# Optional: server port (default: 3000)
PORT=3000

# Optional: development | production | test (default: none)
NODE_ENV=development

# Optional: log level — trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# Optional: allowed CORS origin (default: * in dev — restrict in prod)
# CORS_ORIGIN=https://your-frontend.example.com

# Optional: rate limiter window in seconds (default: 60)
# THROTTLE_TTL=60

# Optional: max requests per window (default: 100)
# THROTTLE_LIMIT=100

# --- AI Provider ---
# Optional: which AiProvider implementation to use — fake | openai (default: fake)
AI_PROVIDER=fake

# Required when AI_PROVIDER=openai: OpenAI API key
# OPENAI_API_KEY=sk-your-key-here

# Optional: OpenAI model name (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Reserved for future step-level provider/model overrides (not read by current code)
# AI_PROVIDER_DEFAULT=openai
# AI_MODEL_DEFAULT=gpt-4o
