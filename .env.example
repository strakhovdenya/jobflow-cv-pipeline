# Used by docker-compose.yml (at repo root) for variable substitution when
# starting the local Postgres/Redis containers. This is intentionally a
# small subset — the backend app's own runtime config (DATABASE_URL,
# STORAGE_ROOT, API_KEY, AI provider settings, etc.) lives in
# apps/api/.env, not here.

POSTGRES_USER=jobflow
POSTGRES_PASSWORD=jobflow_secret
POSTGRES_DB=jobflow_cv
POSTGRES_PORT=5432

REDIS_PORT=6379

PORT=3000
WEB_PORT=3001

# Optional: override the API base URL baked into the apps/web container's
# client bundle at build time (default: http://app:3000, the in-network
# service name — correct for the default single-host compose setup).
# NEXT_PUBLIC_API_BASE_URL=http://app:3000
